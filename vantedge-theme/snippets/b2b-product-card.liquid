{%- comment -%}
  Renders a single B2B product card for the Company Standards grid.
  Usage: {% render 'b2b-product-card', product: product %}
{%- endcomment -%}

{%- liquid
  assign variant = product.first_available_variant | default: product.variants.first
-%}

<div
  class="b2b-product-card"
  data-title="{{ product.title | downcase | escape }}"
  data-vendor="{{ product.vendor | downcase | escape }}"
  data-sku="{{ variant.sku | escape }}"
  data-category="{{ product.type | downcase | escape }}"
  data-variant-id="{{ variant.id }}"
>
  <a href="{{ product.url }}" class="b2b-product-card__img-wrap" tabindex="-1" aria-hidden="true">
    {%- if product.featured_image -%}
      <img
        class="b2b-product-card__img"
        src="{{ product.featured_image | image_url: width: 300 }}"
        alt="{{ product.featured_image.alt | escape }}"
        loading="lazy"
        width="300"
        height="300"
      >
    {%- else -%}
      <svg class="b2b-product-card__img-placeholder" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="2"/>
        <path d="m3 9 4-4 4 4 4-4 4 4"/>
        <circle cx="8.5" cy="13.5" r="1.5"/>
      </svg>
    {%- endif -%}
  </a>

  <div class="b2b-product-card__body">
    {%- if product.vendor != blank -%}
      <div class="b2b-product-card__vendor">{{ product.vendor }}</div>
    {%- endif -%}

    <a href="{{ product.url }}" class="b2b-product-card__title">{{ product.title }}</a>

    {%- if variant.sku != blank -%}
      <div class="b2b-product-card__sku">SKU: {{ variant.sku }}</div>
    {%- endif -%}

    <div class="b2b-product-card__price">
      {%- if variant.available -%}
        {{ variant.price | money }}
        {%- if variant.compare_at_price > variant.price -%}
          <s style="color:#9ca3af;font-weight:400;font-size:0.8rem;margin-left:0.25rem">{{ variant.compare_at_price | money }}</s>
        {%- endif -%}
      {%- else -%}
        <span style="color:#9ca3af;font-size:0.85rem">Out of stock</span>
      {%- endif -%}
    </div>
  </div>

  <div class="b2b-product-card__footer">
    <div class="b2b-qty-wrap" style="display:flex;gap:0.25rem;align-items:center">
      <button
        type="button"
        class="b2b-btn b2b-btn--outline b2b-btn--sm"
        data-qty-step="-1"
        aria-label="Decrease quantity"
        style="padding:0.375rem 0.6rem;flex-shrink:0"
      >−</button>
      <input
        type="number"
        class="b2b-qty-input"
        value="1"
        min="1"
        aria-label="Quantity"
        style="width:44px"
      >
      <button
        type="button"
        class="b2b-btn b2b-btn--outline b2b-btn--sm"
        data-qty-step="1"
        aria-label="Increase quantity"
        style="padding:0.375rem 0.6rem;flex-shrink:0"
      >+</button>
    </div>

    <button
      type="button"
      class="b2b-btn b2b-btn--primary"
      data-add-to-cart
      {%- unless variant.available %} disabled{%- endunless %}
      aria-label="Add {{ product.title | escape }} to cart"
    >
      {%- if variant.available -%}Add to Cart{%- else -%}Out of Stock{%- endif -%}
    </button>
  </div>
</div>
