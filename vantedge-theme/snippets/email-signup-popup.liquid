{%- comment -%}
  Email-capture popup: offers 10% off (code WELCOME10) for joining the email list.
  Subscribes the email to Klaviyo "Email List" (SAMsQ3) via the client subscriptions API,
  which triggers the existing Welcome flow that delivers the code.
  Shown once per visitor (localStorage), after a short delay, and NOT to logged-in customers.
{%- endcomment -%}
{%- unless customer -%}
<div id="uw-signup" class="uw-signup" hidden role="dialog" aria-modal="true" aria-labelledby="uw-signup-title">
  <div class="uw-signup__overlay" data-uw-close></div>
  <div class="uw-signup__card">
    <button class="uw-signup__x" type="button" aria-label="Close" data-uw-close>&times;</button>
    <div class="uw-signup__body">
      <h2 id="uw-signup-title" class="uw-signup__title">Get 10% off your first order</h2>
      <p class="uw-signup__sub">Join our list for a one-time 10% off code, plus deals on business &amp; office tech.</p>
      <form class="uw-signup__form" novalidate>
        <input class="uw-signup__email" type="email" name="email" placeholder="you@email.com" autocomplete="email" required>
        <button class="uw-signup__btn" type="submit">Get my 10% off</button>
      </form>
      <p class="uw-signup__msg" hidden></p>
      <button class="uw-signup__no" type="button" data-uw-close>No thanks</button>
    </div>
  </div>
</div>

<style>
  .uw-signup[hidden]{display:none}
  .uw-signup{position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;padding:16px}
  .uw-signup__overlay{position:absolute;inset:0;background:rgba(11,18,32,.55)}
  .uw-signup__card{position:relative;background:#fff;border-radius:12px;max-width:420px;width:100%;padding:28px 26px;box-shadow:0 20px 60px rgba(0,0,0,.3);text-align:center}
  .uw-signup__x{position:absolute;top:8px;right:12px;background:none;border:0;font-size:26px;line-height:1;cursor:pointer;color:#64748b}
  .uw-signup__title{margin:0 0 8px;font-size:22px;color:#0b1220;line-height:1.25}
  .uw-signup__sub{margin:0 0 18px;font-size:14px;color:#475569;line-height:1.5}
  .uw-signup__form{display:flex;flex-direction:column;gap:10px}
  .uw-signup__email{padding:12px 14px;border:1px solid #cbd5e1;border-radius:8px;font-size:15px;width:100%}
  .uw-signup__btn{padding:13px 16px;background:#0ea5e9;color:#fff;border:0;border-radius:8px;font-weight:600;font-size:15px;cursor:pointer}
  .uw-signup__btn:disabled{opacity:.6;cursor:default}
  .uw-signup__msg{margin:14px 0 0;font-size:14px}
  .uw-signup__msg--ok{color:#16a34a}
  .uw-signup__msg--err{color:#dc2626}
  .uw-signup__no{margin-top:14px;background:none;border:0;color:#94a3b8;font-size:13px;cursor:pointer;text-decoration:underline}
</style>

<script>
  (function () {
    var KEY = 'XhQyvC';          // Klaviyo public (company) key
    var LIST = 'SAMsQ3';         // Klaviyo "Email List" (triggers Welcome flow)
    var SEEN = 'uw_signup_seen';
    var root = document.getElementById('uw-signup');
    if (!root) return;
    try { if (localStorage.getItem(SEEN)) return; } catch (e) {}

    var form = root.querySelector('.uw-signup__form');
    var email = root.querySelector('.uw-signup__email');
    var btn = root.querySelector('.uw-signup__btn');
    var msg = root.querySelector('.uw-signup__msg');

    function open() { root.hidden = false; }
    function close() { root.hidden = true; try { localStorage.setItem(SEEN, '1'); } catch (e) {} }
    root.querySelectorAll('[data-uw-close]').forEach(function (el) { el.addEventListener('click', close); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && !root.hidden) close(); });

    var t = setTimeout(open, 6000); // show after 6s

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var val = (email.value || '').trim();
      if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(val)) {
        msg.hidden = false; msg.className = 'uw-signup__msg uw-signup__msg--err'; msg.textContent = 'Please enter a valid email.';
        return;
      }
      btn.disabled = true; btn.textContent = 'Signing you up…';
      fetch('https://a.klaviyo.com/client/subscriptions/?company_id=' + KEY, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', revision: '2024-10-15' },
        body: JSON.stringify({
          data: {
            type: 'subscription',
            attributes: { profile: { data: { type: 'profile', attributes: { email: val } } } },
            relationships: { list: { data: { type: 'list', id: LIST } } }
          }
        })
      }).then(function (r) {
        if (r.ok) {
          form.hidden = true;
          msg.hidden = false; msg.className = 'uw-signup__msg uw-signup__msg--ok';
          msg.textContent = "You're in! Check your email for your 10% off code (WELCOME10).";
          try { localStorage.setItem(SEEN, '1'); } catch (e) {}
        } else {
          throw new Error('subscribe failed ' + r.status);
        }
      }).catch(function () {
        btn.disabled = false; btn.textContent = 'Get my 10% off';
        msg.hidden = false; msg.className = 'uw-signup__msg uw-signup__msg--err';
        msg.textContent = 'Something went wrong — please try again.';
      });
    });
  })();
</script>
{%- endunless -%}
