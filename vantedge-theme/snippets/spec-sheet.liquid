{%- liquid
  assign spec_groups = product.metafields.custom.spec_sheet.value
-%}

{%- if spec_groups != blank and spec_groups.size > 0 -%}
<div class="product__accordion accordion quick-add-hidden spec-sheet">
  <details id="SpecSheet-{{ product.id }}">
    <summary>
      <div class="summary__title">
        <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
          <rect x="9" y="3" width="6" height="4" rx="1"/>
          <line x1="9" y1="12" x2="15" y2="12"/>
          <line x1="9" y1="16" x2="13" y2="16"/>
        </svg>
        <h2 class="h4 accordion__title">Specifications</h2>
      </div>
      {{- 'icon-caret.svg' | inline_asset_content -}}
    </summary>
    <div class="accordion__content spec-sheet__content">
      {%- for group in spec_groups -%}
        {%- if group.specs.size > 0 -%}
          <div class="spec-sheet__group">
            <h3 class="spec-sheet__group-title">{{ group.group }}</h3>
            <table class="spec-sheet__table">
              <tbody>
                {%- for spec in group.specs -%}
                  <tr>
                    <th class="spec-sheet__name">{{ spec.name }}</th>
                    <td class="spec-sheet__value">{{ spec.value }}</td>
                  </tr>
                {%- endfor -%}
              </tbody>
            </table>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </details>
</div>

<style>
  .spec-sheet__content {
    padding: 0 0 1.6rem;
  }
  .spec-sheet__group {
    margin-bottom: 2rem;
  }
  .spec-sheet__group:last-child {
    margin-bottom: 0;
  }
  .spec-sheet__group-title {
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.6);
    margin: 0 0 0.8rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.1);
  }
  .spec-sheet__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 1.3rem;
  }
  .spec-sheet__table tr:nth-child(even) {
    background: rgba(var(--color-foreground), 0.03);
  }
  .spec-sheet__name {
    width: 42%;
    padding: 0.5rem 1rem 0.5rem 0;
    font-weight: 500;
    color: rgba(var(--color-foreground), 0.75);
    vertical-align: top;
    text-align: left;
  }
  .spec-sheet__value {
    padding: 0.5rem 0;
    color: rgb(var(--color-foreground));
    vertical-align: top;
  }
</style>
{%- endif -%}
