{% comment %}
  Brand Carousel — highlights top brands and links to their collection pages.
  Each brand is a configurable block: logo image, brand name, and collection URL.
  Upload brand logos via the theme customizer. Logos are shown in greyscale and
  animate to full colour on hover.
{% endcomment %}

{{ 'section-brand-carousel.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }} {
    --brand-carousel-padding-top: {{ section.settings.padding_top }}px;
    --brand-carousel-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<div class="brand-carousel color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}">
  <div class="page-width">

    {%- if section.settings.title != blank -%}
      <div class="brand-carousel__heading">
        <h2 class="title inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.title }}
        </h2>
      </div>
    {%- endif -%}

    <div class="brand-carousel__wrapper">
      {%- if section.blocks.size > 4 -%}
        <button
          class="brand-carousel__btn brand-carousel__btn--prev"
          onclick="this.closest('.brand-carousel__wrapper').querySelector('.brand-carousel__track').scrollBy({left:-320,behavior:'smooth'})"
          aria-label="Previous brands"
        >
          <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
      {%- endif -%}

      <div class="brand-carousel__track" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'brand' -%}
            <a
              href="{{ block.settings.link | default: '/collections/all-products' }}"
              class="brand-carousel__item"
              role="listitem"
              aria-label="{{ block.settings.brand_name | escape }}"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.logo != blank -%}
                {{
                  block.settings.logo
                  | image_url: width: 240
                  | image_tag:
                    class: 'brand-carousel__logo',
                    alt: block.settings.brand_name,
                    loading: 'lazy',
                    widths: '120, 180, 240'
                }}
              {%- else -%}
                <span class="brand-carousel__name">{{ block.settings.brand_name }}</span>
              {%- endif -%}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if section.blocks.size > 4 -%}
        <button
          class="brand-carousel__btn brand-carousel__btn--next"
          onclick="this.closest('.brand-carousel__wrapper').querySelector('.brand-carousel__track').scrollBy({left:320,behavior:'smooth'})"
          aria-label="Next brands"
        >
          <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      {%- endif -%}
    </div><!-- /.brand-carousel__wrapper -->

    {%- if section.settings.show_all_link and section.settings.all_link != blank -%}
      <div class="brand-carousel__footer">
        <a href="{{ section.settings.all_link }}">{{ section.settings.all_link_label | default: 'Browse all brands' }}</a>
      </div>
    {%- endif -%}

  </div><!-- /.page-width -->
</div>

{% schema %}
{
  "name": "Brand carousel",
  "tag": "section",
  "class": "section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Trusted brands"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h2"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "show_all_link",
      "label": "Show 'Browse all brands' link",
      "default": false
    },
    {
      "type": "url",
      "id": "all_link",
      "label": "Link for 'Browse all brands'"
    },
    {
      "type": "text",
      "id": "all_link_label",
      "label": "Link label",
      "default": "Browse all brands"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand name",
          "info": "Shown as text if no logo is uploaded"
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Brand logo",
          "info": "Recommended: SVG or transparent PNG, 240 × 80 px"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Collection link",
          "info": "Link to the brand's collection or search page"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand carousel",
      "blocks": [
        {
          "type": "brand",
          "settings": {
            "brand_name": "ASUS",
            "link": "/collections/asus"
          }
        },
        {
          "type": "brand",
          "settings": {
            "brand_name": "Dell",
            "link": "/collections/dell"
          }
        },
        {
          "type": "brand",
          "settings": {
            "brand_name": "Lenovo",
            "link": "/collections/lenovo"
          }
        },
        {
          "type": "brand",
          "settings": {
            "brand_name": "Apple",
            "link": "/collections/apple"
          }
        },
        {
          "type": "brand",
          "settings": {
            "brand_name": "Logitech",
            "link": "/collections/logitech"
          }
        },
        {
          "type": "brand",
          "settings": {
            "brand_name": "Acer",
            "link": "/collections/acer"
          }
        }
      ]
    }
  ]
}
{% endschema %}
