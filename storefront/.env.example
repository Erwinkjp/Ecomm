# Shopify Storefront API (Headless channel)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_api_token

# Collection handle for the home page “hot products” carousel (create in Shopify Admin → Products → Collections)
NEXT_PUBLIC_FEATURED_COLLECTION_HANDLE=featured

# Optional: public shop URL if you use a custom domain (product links)
# NEXT_PUBLIC_STORE_URL=https://your-store.com

# Optional: POST webhook for discount signups (Zapier, Make, etc.)
# SUBSCRIBE_WEBHOOK_URL=https://hooks.zapier.com/...

# Shopify Admin API — required for order lookup (/order-status) and returns (/returns).
# Generate at: Shopify Admin → Settings → Apps and sales channels → Develop apps
# Scopes needed: read_orders, write_returns
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
