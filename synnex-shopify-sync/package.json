{
  "name": "synnex-shopify-sync",
  "version": "2.0.0",
  "description": "AWS Lambda: TD Synnex XML catalog and pricing → Shopify product sync",
  "main": "src/handler.js",
  "scripts": {
    "build": "sam build",
    "deploy": "sam build && sam deploy",
    "invoke:catalog": "sam local invoke SyncFunction --event events/catalog-sync.json",
    "invoke:price": "sam local invoke SyncFunction --event events/price-sync.json"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-secrets-manager": "^3.700.0",
    "@aws-sdk/util-dynamodb": "^3.700.0",
    "adm-zip": "^0.5.16",
    "fast-xml-parser": "^4.5.0",
    "ssh2-sftp-client": "^11.0.0"
  }
}
